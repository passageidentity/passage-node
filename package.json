{
  "version": "2.2.1",
  "devDependencies": {
    "@types/express": "^4.17.13",
    "@types/jest": "^27.0.1",
    "@types/node": "^16.9.0",
    "@types/pem": "^1.9.6",
    "@types/supertest": "^2.0.11",
    "@typescript-eslint/eslint-plugin": "^5.8.0",
    "@typescript-eslint/parser": "^5.8.0",
    "babel-jest": "^27.2.0",
    "beachball": "^2.20.0",
    "dotenv": "^10.0.0",
    "eslint": "^8.5.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "express": "^4.17.1",
    "husky": "^7.0.4",
    "jest": "^27.2.0",
    "npm-run-all2": "^6.0.5",
    "prettier": "^2.5.1",
    "pretty-quick": "^3.1.3",
    "supertest": "^6.1.6",
    "ts-jest": "^27.0.5",
    "ts-node-dev": "^1.1.8",
    "tsup": "^6.7.0",
    "typescript": "^4.9.5"
  },
  "name": "@passageidentity/passage-node",
  "main": "./lib/cjs/index.js",
  "module": "./lib/esm/index.js",
  "files": [
    "lib/"
  ],
  "scripts": {
    "lint": "eslint 'src/**/*.ts?(x)' --fix",
    "lint:ci": "eslint 'src/**/*.ts?(x)'",
    "format": "pretty-quick --staged",
    "prepare": "husky install",
    "dev": "ts-node-dev --respawn testServer.ts",
    "test": "jest",
    "build:deno": "npm run-script runtime-deno && find dist/deno -name '*.ts' -type f -print0 | xargs -0 sed -i.bak -e \"s/\\.js'/.ts'/g\" -e \"s/\\.d'/.d.ts'/g\" && npm run-script sedcleanup",
    "test:watch": "jest --watch",
    "tsc": "tsc -p tsconfig.json && tsc -p tsconfig-cjs.json",
    "change": "beachball change",
    "publish": "beachball publish -y -n",
    "set-version": "echo '{\"version\":\"'$npm_package_name' '$npm_package_version'\"}' > ./src/utils/config.json",
    "beachball-bump": "beachball bump",
    "beachball-check": "beachball check",
    "sedcleanup": "find . -name '*.bak' -type f -print0 | xargs -0 rm -f",
    "runtime-deno": "mkdir -p dist/deno && cp -R src/. dist/deno",
    "runtime:clear": "run-s -s runtime:find | xargs -0 rm -f",
    "runtime:refs": "run-s -s runtime:find | xargs -0 sed -i.bak -e \"s/'\\.\\.\\//'\\.\\//g\" -e \"s/'\\.\\/\\.\\./'../g\" && npm run-script sedcleanup"
  },
  "keywords": [
    "passage",
    "identity",
    "passageidentity",
    "authentication",
    "login"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "bun": "./dist/browser/index.js",
      "deno": "./dist/browser/index.js",
      "browser": "./dist/browser/index.js",
      "worker": "./dist/browser/index.js",
      "import": "./dist/node/esm/index.js",
      "require": "./dist/node/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "author": "Passage Identity",
  "license": "MIT",
  "description": "",
  "dependencies": {
    "axios": "^0.21.4",
    "jose": "^4.14.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
